# Backend selection — see ARCHITECTURE.md §4 (provider interfaces)
OCR_BACKEND=paddle           # paddle | surya | sarvam_vision
TTS_BACKEND=indic_parler     # indic_parler | indicf5 | bulbul
LLM_BACKEND=none             # none | sarvam_m | sarvam_translate
DEVICE=mps                   # mps | cuda | cpu
PREPROCESS_IMAGES=false      # deskew/contrast/crop a page before OCR

# Sarvam API — set only when using a sarvam_* OCR/LLM or the bulbul TTS backend
SARVAM_API_KEY=

# Telegram bot (v0 client)
TELEGRAM_BOT_TOKEN=

# Hugging Face token — needed for gated models like ai4bharat/indic-parler-tts.
# Accept access at https://huggingface.co/ai4bharat/indic-parler-tts first,
# or run `uv run hf auth login` instead of setting this.
HF_TOKEN=
